{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "description": "Hello World Bun Template",
  "scripts": {
    "dev": "bun run --watch src/index.ts serve",
    "index": "bun run src/index.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "typegen": "rm -rf .types && bunx tsc -p tsconfig.types.json"
  },
  "dependencies": {
    "@drsmile1001/logger": "^2.0.0",
    "@drsmile1001/service-map": "^1.0.0",
    "@drsmile1001/system-time": "^1.0.0",
    "@drsmile1001/utils": "^1.0.0",
    "@sinclair/typebox": "^0.34.48",
    "cac": "^7.0.0",
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
