{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": ".types",
    "rootDir": ".",
    "noEmit": false,
    "composite": false,
    "isolatedModules": false
  },
  "include": ["src/public.ts"],
  "exclude": ["test/**/*.ts", "dist", "node_modules", ".types"]
}
