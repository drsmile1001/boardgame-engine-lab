{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -b && bunx --bun vite build",
    "preview": "vite preview",
    "typecheck": "bun run --cwd ../backend typegen && bunx tsc -p tsconfig.app.json --noEmit && bunx tsc -p tsconfig.node.json --noEmit && bunx tsc -p tsconfig.test.json --noEmit",
    "test": "bun test test",
    "test:watch": "bun test --watch test"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@tailwindcss/vite": "^4.2.1",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  }
}
